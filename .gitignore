node_modules/
.webpack-cache/
.DS_Store

# Clinical Co-Pilot agent + auth-bridge secrets (real API keys / OAuth client secrets -- never commit)
agent/.env
agent/venv/
agent/**/__pycache__/
agent/.coverage

# Week 3 adversarial platform secrets (Anthropic key, dedicated OpenEMR test login, Postgres URL)
redteam/.env
redteam/venv/
redteam/**/__pycache__/
# Rebuildable Voyage embedding cache for the Week 2 guideline corpus (agent/app/rag.py) -- derived
# from agent/data/guidelines/*.md, regenerated automatically on first run after a corpus change.
agent/data/guidelines_index_cache.json
interface/modules/copilot/config.php

# Local Claude Code settings (personal, machine-specific)
.claude/settings.local.json

# OpenEMR CryptoGen key material -- bootstrapped per-deployment on the persistent volume; committing
# these would let anyone with repo access decrypt stored secrets (e.g. oauth_clients.client_secret)
sites/default/documents/certificates/
sites/default/documents/logs_and_misc/methods/

# Uploaded patient documents (OpenEMR stores these under sites/default/documents/<pid>/) -- runtime
# instance data from local Week 2 ingestion testing, not source code; never commit patient files
# even when synthetic, matching the same "instance-specific, gitignored" treatment as the two
# directories above.
sites/default/documents/[0-9]*/
