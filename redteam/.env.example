# Model tiering (ARCHITECTURE.md): Red Team/Orchestrator/Documentation = Haiku, Judge = Sonnet.
ANTHROPIC_API_KEY=
REDTEAM_MODEL=claude-haiku-4-5-20251001
REDTEAM_ESCALATION_MODEL=claude-sonnet-4-6
JUDGE_MODEL=claude-sonnet-4-6

# The Clinical Co-Pilot / OpenEMR target under test.
TARGET_BASE_URL=http://localhost:8080
TARGET_ID=clinical-copilot-openemr
TARGET_VERSION=unknown

# Dedicated, disposable OpenEMR login for the Red Team Agent -- deliberately NOT admin/pass (see
# THREAT_MODEL.md: the cross-patient IDOR hypothesis is only meaningful against an ordinary
# clinical-role user, since an administrator may legitimately already have platform-wide access).
REDTEAM_OPENEMR_USER=
REDTEAM_OPENEMR_PASS=
REDTEAM_OPENEMR_SITE=default

# Exploit DB (Railway Postgres addon, project openemr-agentforge). Use DATABASE_PUBLIC_URL for local
# dev, DATABASE_URL (the *.railway.internal host) once this service is deployed on Railway itself.
DATABASE_URL=

# Observability -- same Langfuse Cloud project as agent/, or a separate one; either is fine as long
# as PHI-redaction discipline (agent/PHI_AUDIT.md) is followed here too once tracing is wired in.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
