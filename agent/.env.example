# Anthropic API key. Under a signed BAA before any real PHI is sent in production (see ARCHITECTURE.md).
ANTHROPIC_API_KEY=

# Model is swappable without a code change (see agent-implementation.md decision #4).
ANTHROPIC_MODEL=claude-sonnet-4-6

# Base URL of OpenEMR's FHIR API.
FHIR_BASE_URL=http://localhost:8080/apis/default/fhir

# Base URL of OpenEMR's standard (non-FHIR) REST API -- Week 2 document upload and the
# procedure_result_from_document write path both live here, not in the FHIR API
# (W2_ARCHITECTURE.md Section 2).
OEMR_API_BASE_URL=http://localhost:8080/apis/default/api

# TEMPORARY dev-only bearer token, obtained via OpenEMR's OAuth2 password grant (see agent/README.md).
# This stands in for the real per-session token the auth-bridge endpoint will mint later — the agent
# itself doesn't yet know or care how the token was obtained, it just uses whatever it's given.
DEV_BEARER_TOKEN=

# Langfuse Cloud tracing (observability requirement, agent-implementation.md decision #3).
# PHI is redacted before it reaches Langfuse Cloud -- see PHI_AUDIT.md for the full call-site
# inventory/justification, and LANGFUSE_SELFHOST.md for the deferred full self-host plan (Option A)
# if this redaction approach is ever judged insufficient. Get these from a Langfuse Cloud project's
# Settings -> API Keys. Leave blank to run the agent with tracing disabled (the @observe decorators
# no-op without credentials).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Salt used to hash the FHIR patient UUID before it's used as a Langfuse session_id (see
# PHI_AUDIT.md). Not a security control, just keeps the raw patient identifier out of the
# third-party trace payload -- set any random string in production.
LANGFUSE_SESSION_SALT=

# Week 2 hybrid RAG (W2_ARCHITECTURE.md Section 4) -- one vendor for both embeddings and rerank
# instead of adding Cohere as a second vendor (see W2_ARCHITECTURE.md Section 12). Get a key at
# https://www.voyageai.com/ (free tier is enough for this small guideline corpus). Leave blank to
# run without RAG -- /ready reports the vector_index/voyage_api checks as "degraded", not "down",
# and evidence_retriever degrades to "no guideline evidence found" rather than crashing.
VOYAGE_API_KEY=
VOYAGE_EMBED_MODEL=voyage-3-lite
VOYAGE_RERANK_MODEL=rerank-2
